{
  "name": "duck-dry",
  "description": "Use for DRY review to find meaningful duplication and divergence risk with safe extraction boundaries.",
  "harnesses": {
    "claude": {
      "tools": "Read, Glob, Grep, Skill"
    },
    "copilot": {
      "tools": "read,search"
    },
    "opencode": {
      "mode": "subagent",
      "permission": {
        "read": "allow",
        "grep": "allow",
        "glob": "allow",
        "bash": "deny",
        "edit": "deny",
        "task": "deny",
        "skill": "allow",
        "lsp": "allow",
        "question": "deny"
      }
    }
  }
}
